# GenLayer Configuration (The Brain)
VITE_GENLAYER_RPC_URL=https://studio.genlayer.com/rpc
VITE_GENLAYER_CONTRACT_ADDRESS=

# Circle Developer Wallet Configuration (The Muscle)
# Get these from the Circle Web3 Services Console
CIRCLE_API_KEY=your_circle_api_key_here
CIRCLE_WALLET_ID=your_developer_wallet_id
CIRCLE_ENTITY_SECRET=your_32_byte_entity_secret

# Toggle this to 'false' when you are ready to connect the real APIs instead of the demo mock
VITE_MOCK_MODE=true
